{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AllChemist",
  "version": "0.1.0",
  "identifier": "com.usgromov.allchemist.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../../mobile/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AllChemist",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  }
}
