{
  "name": "allchemist-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "web:remote": "npx expo start --web --host lan --port 19006",
    "web:export": "npx expo export --platform web",
    "smoke:migration": "node scripts/smoke-device-migration.js",
    "apk:preflight": "node scripts/preflight-apk-demo.js",
    "apk:build:demo": "npm run apk:preflight && npx eas build --platform android --profile demo-apk --non-interactive",
    "quality:content": "python3 ../tools/content_quality_guard.py --check"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "axios": "^1.7.0",
    "expo": "~52.0.0",
    "expo-application": "~6.0.1",
    "expo-asset": "~11.0.5",
    "expo-background-fetch": "~13.0.6",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-gl": "~15.0.5",
    "expo-modules-autolinking": "~2.0.0",
    "expo-modules-core": "~2.2.3",
    "expo-notifications": "~0.29.14",
    "expo-sqlite": "~15.1.4",
    "expo-task-manager": "~12.0.6",
    "expo-three": "^8.0.0",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "three": "^0.166.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.9.3"
  }
}
